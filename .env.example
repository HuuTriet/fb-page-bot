PORT=3000

# Facebook App (Settings → Basic)
FB_APP_ID=
FB_APP_SECRET=

# Page (lấy từ Graph API Explorer hoặc Page Settings)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# Webhook (tự đặt 1 chuỗi random, dùng cho cả Facebook lẫn webhook URL ở Render)
FB_VERIFY_TOKEN=change_me_to_a_random_string

# Groq (free tier — get key at https://console.groq.com/keys)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Admin REST API (tự đặt 1 chuỗi random — dùng để gọi /admin endpoints)
ADMIN_TOKEN=change_me_to_another_random_string

# Bot
TIMEZONE=Asia/Ho_Chi_Minh
